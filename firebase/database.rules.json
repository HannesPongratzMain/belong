{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "data.exists() || newData.child('ageConfirmed').val() === true",
        "nickname": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 30"
        },
        "ageConfirmed": {
          ".validate": "newData.val() === true"
        },
        "anonymityLevel": {
          ".validate": "newData.val() === 'anonymous' || newData.val() === 'nickname' || newData.val() === 'nicknameInterests'"
        },
        "verificationLevel": {
          ".validate": "newData.val() === 'none' || newData.val() === 'phone'"
        }
      }
    },
    "activities": {
      ".read": "auth != null",
      ".indexOn": ["startsAt", "area"],
      "$activityId": {
        ".write": "auth != null && (!data.exists() ? newData.child('hostId').val() === auth.uid && root.child('users').child(auth.uid).child('verificationLevel').val() === 'phone' && root.child('users').child(auth.uid).child('ageConfirmed').val() === true : data.child('hostId').val() === auth.uid)",
        "title": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 80"
        },
        "description": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "category": {
          ".validate": "newData.val() === 'draussen' || newData.val() === 'tanzen' || newData.val() === 'spiele' || newData.val() === 'musik' || newData.val() === 'essen' || newData.val() === 'kaffee'"
        },
        "participantCount": {
          ".write": "auth != null && (newData.val() === data.val() + 1 || newData.val() === data.val() - 1)"
        },
        "precise": {
          ".read": "auth != null && root.child('activityParticipants').child($activityId).child(auth.uid).exists()",
          "address": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 200"
          }
        }
      }
    },
    "participations": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "activityParticipants": {
      "$activityId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && $uid === auth.uid && root.child('users').child($uid).child('verificationLevel').val() === 'phone' && root.child('users').child($uid).child('ageConfirmed').val() === true"
        }
      }
    },
    "chats": {
      "$activityId": {
        ".read": "auth != null && root.child('activityParticipants').child($activityId).child(auth.uid).exists()",
        "messages": {
          ".indexOn": ["sentAt"],
          "$messageId": {
            ".write": "auth != null && root.child('activityParticipants').child($activityId).child(auth.uid).exists() && !data.exists() && newData.child('senderId').val() === auth.uid",
            "text": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 500"
            }
          }
        },
        "polls": {
          "$pollId": {
            ".write": "auth != null && root.child('activityParticipants').child($activityId).child(auth.uid).exists() && root.child('activities').child($activityId).child('hostId').val() === auth.uid && !data.exists() && newData.child('createdBy').val() === auth.uid",
            "question": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 200"
            },
            "options": {
              ".validate": "newData.hasChildren(['0','1']) && newData.numChildren() <= 6",
              "$index": {
                ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 80"
              }
            },
            "allowMultiple": {
              ".validate": "newData.isBoolean()"
            },
            "votes": {
              "$uid": {
                ".write": "auth != null && $uid === auth.uid && root.child('activityParticipants').child($activityId).child(auth.uid).exists()",
                ".validate": "root.child('chats').child($activityId).child('polls').child($pollId).child('allowMultiple').val() === true ? newData.hasChildren() : (newData.isNumber() && newData.val() >= 0 && newData.val() < root.child('chats').child($activityId).child('polls').child($pollId).child('options').numChildren())",
                "$index": {
                  ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() < root.child('chats').child($activityId).child('polls').child($pollId).child('options').numChildren()"
                }
              }
            }
          }
        },
        "meta": {
          "pinnedMessageId": {
            ".write": "auth != null && root.child('activities').child($activityId).child('hostId').val() === auth.uid && (newData.val() === null || (newData.isString() && root.child('chats').child($activityId).child('messages').child(newData.val()).exists()))"
          },
          "pinnedAt": {
            ".write": "auth != null && root.child('activities').child($activityId).child('hostId').val() === auth.uid"
          }
        }
      }
    },
    "friendRequests": {
      "$toUserId": {
        ".read": "auth != null && auth.uid === $toUserId",
        "$fromUserId": {
          ".write": "auth != null && (auth.uid === $toUserId || (auth.uid === $fromUserId && !data.exists() && root.child('users').child(auth.uid).child('verificationLevel').val() === 'phone' && root.child('users').child($toUserId).child('verificationLevel').val() === 'phone'))",
          "fromNickname": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 30"
          }
        }
      }
    },
    "friendships": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$friendUid": {
          ".write": "auth != null && (auth.uid === $uid || (auth.uid === $friendUid && root.child('friendRequests').child(auth.uid).child($uid).exists()))",
          "nickname": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 30"
          }
        }
      }
    },
    "moderation": {
      "reports": {
        "$reportId": {
          ".read": false,
          ".write": "auth != null && !data.exists()"
        }
      },
      "blocks": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          "$blockedUid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      },
      "mutes": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          "$activityId": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    }
  }
}

{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "data.exists() || newData.child('ageConfirmed').val() === true",
        "nickname": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 30"
        },
        "ageConfirmed": {
          ".validate": "newData.val() === true"
        },
        "anonymityLevel": {
          ".validate": "newData.val() === 'anonymous' || newData.val() === 'nickname' || newData.val() === 'nicknameInterests'"
        },
        "verificationLevel": {
          ".validate": "newData.val() === 'none' || newData.val() === 'phone'"
        }
      }
    },
    "activities": {
      ".read": "auth != null",
      ".indexOn": ["startsAt", "area"],
      "$activityId": {
        ".write": "auth != null && (!data.exists() ? newData.child('hostId').val() === auth.uid && root.child('users').child(auth.uid).child('verificationLevel').val() === 'phone' && root.child('users').child(auth.uid).child('ageConfirmed').val() === true : data.child('hostId').val() === auth.uid)",
        "title": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 80"
        },
        "description": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "category": {
          ".validate": "newData.val() === 'draussen' || newData.val() === 'tanzen' || newData.val() === 'spiele' || newData.val() === 'musik' || newData.val() === 'essen' || newData.val() === 'kaffee'"
        },
        "participantCount": {
          ".write": "auth != null && (newData.val() === data.val() + 1 || newData.val() === data.val() - 1)"
        },
        "precise": {
          ".read": "auth != null && root.child('activityParticipants').child($activityId).child(auth.uid).exists()",
          "address": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 200"
          }
        }
      }
    },
    "participations": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "activityParticipants": {
      "$activityId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && $uid === auth.uid && root.child('users').child($uid).child('verificationLevel').val() === 'phone' && root.child('users').child($uid).child('ageConfirmed').val() === true"
        }
      }
    },
    "chats": {
      "$activityId": {
        ".read": "auth != null && root.child('activityParticipants').child($activityId).child(auth.uid).exists()",
        "messages": {
          ".indexOn": ["sentAt"],
          "$messageId": {
            ".write": "auth != null && root.child('activityParticipants').child($activityId).child(auth.uid).exists() && !data.exists() && newData.child('senderId').val() === auth.uid",
            "text": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 500"
            }
          }
        }
      }
    },
    "moderation": {
      "reports": {
        "$reportId": {
          ".read": false,
          ".write": "auth != null && !data.exists()"
        }
      },
      "blocks": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          "$blockedUid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      },
      "mutes": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          "$activityId": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    }
  }
}
